/* ===== iOS Safe-Area Fix (Header/Footer visible) ===== */

/* Fix sticky header being hidden under iOS top UI */
.topbarWrap{
  position: sticky;
  top: 0;
  z-index: 9999;
  padding-top: env(safe-area-inset-top);
}

/* Ensure footer not hidden behind iOS home indicator */
.footerFull{
  padding-bottom: calc(14px + env(safe-area-inset-bottom));
}

/* Give page content breathing so footer isn't "cut" */
.main{
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== iOS SAFE-AREA FIX (header/footer visible on iPhone) ===== */
:root{
  --sat: env(safe-area-inset-top);
  --sab: env(safe-area-inset-bottom);
}

/* Make the main shell use the real dynamic viewport */
html, body { height: 100%; }
.main{
  min-height: 100dvh;
  display: flex;
  flex-direction: column;
}

/* Content takes remaining space so footer stays at bottom naturally */
.contentWrap{ flex: 1 1 auto; }

/* Header: push below notch / dynamic island */
.topbarWrap{
  top: var(--sat);
  padding-top: var(--sat);
}

/* Footer: add extra bottom padding so Safari bottom bar doesn't cover it */
.footerFull{
  padding-bottom: calc(14px + var(--sab));
}

/* Extra breathing room at the very bottom */
.main{
  padding-bottom: var(--sab);
}


/* =========================================================
   FIX iOS Sticky Header Overlap (safe-area + content offset)
   ========================================================= */
:root{
  --headerH: 96px; /* fallback if JS not used */
}

/* Stick header below iOS safe-area */
.topbarWrap{
  top: env(safe-area-inset-top);
}

/* Push content below sticky header */
.contentWrap{
  padding-top: calc(var(--headerH) + env(safe-area-inset-top) + 12px);
}

/* Make sure footer not hidden behind iOS home indicator */
.footerFull{
  padding-bottom: calc(14px + env(safe-area-inset-bottom));
}

/* =========================================================
   GLOBAL OVERRIDES: Kill Sidebar + Glass UI + Fix header overlap
   ========================================================= */

/* Kill sidebar everywhere */
.sidebar, .side, .navSide, .sidebarWrap, .layout .sidebar{
  display:none !important;
}

/* Ensure layout doesn't reserve sidebar space */
.layout{
  display:block !important;
}
.layout.noSide .main,
.layout .main{
  width: 100% !important;
  margin-left: 0 !important;
}

/* iOS safe areas */
:root{ --headerH: 92px; } /* tweak if needed */

/* Sticky header */
.topbarWrap{
  width: 100%;
  position: sticky;
  top: env(safe-area-inset-top);
  z-index: 1000;
}

/* Push content below header so it never overlaps */
.contentWrap{
  padding-top: calc(var(--headerH) + env(safe-area-inset-top) + 10px);
}

/* Container */
.container{
  width: 100%;
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 18px 40px;
}

/* Footer safe area */
.footerFull{
  padding-bottom: calc(14px + env(safe-area-inset-bottom));
}

/* Make cards glass/transparent (matches background) */
.card, .denyCard, .activity, .kpi, .action{
  background: rgba(255,255,255,.12) !important;
  border: 1px solid rgba(255,255,255,.18) !important;
  backdrop-filter: blur(14px);
  color: #fff !important;
}

/* Muted texts in dark background */
.cardDesc, .muted, .actionHint, .kpiLbl{
  color: rgba(255,255,255,.70) !important;
}

/* Mobile spacing */
@media (max-width: 768px){
  :root{ --headerH: 106px; }
  .container{ padding: 0 14px 34px; }
  .footerInner{ flex-direction: column; align-items: flex-start; }
}


